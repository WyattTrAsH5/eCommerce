@model eCommerce.Models.Product

<h2>Delete Product</h2>

<p class="text-danger">Are you sure you want to delete this product?</p>

<div class="card" style="max-width: 600px;">
    <div class="card-body">
        <h5 class="card-title">@Model.Name</h5>
        <p class="card-text"><strong>Description:</strong> @Model.Description</p>
        <p class="card-text"><strong>Price:</strong> @Model.Price.ToString("C")</p>
        <p class="card-text"><strong>Image URL:</strong> @Model.ImageUrl</p>
    </div>
</div>

<form asp-action="Delete" method="post" class="mt-3">
    <input asp-for="Id" type="hidden" />
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>